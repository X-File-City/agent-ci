{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "website",
  "main": "src/worker.tsx",
  "compatibility_date": "2025-08-21",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "binding": "ASSETS",
  },
  "observability": {
    "enabled": true,
  },
  "vars": {},
  "routes": [
    {
      "pattern": "agent-ci.dev",
      "custom_domain": true,
    },
    {
      "pattern": "www.agent-ci.dev",
      "custom_domain": true,
    },
  ],
}
